{
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.versen.se"
        }
      ],
      "destination": "https://versen.se/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://versen.se/$1",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/produkter.html",
      "destination": "/produkter",
      "permanent": true
    },
    {
      "source": "/products.html",
      "destination": "/produkter",
      "permanent": true
    },
    {
      "source": "/produkt.html",
      "destination": "/produkt",
      "permanent": true
    },
    {
      "source": "/kundkorg.html",
      "destination": "/kundvagn",
      "permanent": true
    },
    {
      "source": "/kundkorg",
      "destination": "/kundvagn",
      "permanent": true
    },
    {
      "source": "/cart.html",
      "destination": "/kundvagn",
      "permanent": true
    },
    {
      "source": "/cart",
      "destination": "/kundvagn",
      "permanent": true
    },
    {
      "source": "/checkout.html",
      "destination": "/checkout",
      "permanent": true
    },
    {
      "source": "/konto.html",
      "destination": "/konto",
      "permanent": true
    },
    {
      "source": "/account.html",
      "destination": "/konto",
      "permanent": true
    },
    {
      "source": "/account",
      "destination": "/konto",
      "permanent": true
    },
    {
      "source": "/medlemskap.html",
      "destination": "/medlemskap",
      "permanent": true
    },
    {
      "source": "/membership.html",
      "destination": "/medlemskap",
      "permanent": true
    },
    {
      "source": "/membership",
      "destination": "/medlemskap",
      "permanent": true
    },
    {
      "source": "/medlemskap-aktivt.html",
      "destination": "/medlemskap-aktivt",
      "permanent": true
    },
    {
      "source": "/drops.html",
      "destination": "/drops",
      "permanent": true
    },
    {
      "source": "/gillar.html",
      "destination": "/gillar",
      "permanent": true
    },
    {
      "source": "/forslag.html",
      "destination": "/forslag",
      "permanent": true
    },
    {
      "source": "/installningar.html",
      "destination": "/installningar",
      "permanent": true
    },
    {
      "source": "/order.html",
      "destination": "/order",
      "permanent": true
    },
    {
      "source": "/villkor.html",
      "destination": "/villkor",
      "permanent": true
    },
    {
      "source": "/integritet.html",
      "destination": "/integritet",
      "permanent": true
    },
    {
      "source": "/returer.html",
      "destination": "/returer",
      "permanent": true
    },
    {
      "source": "/faq.html",
      "destination": "/faq",
      "permanent": true
    },
    {
      "source": "/kontakt.html",
      "destination": "/kontakt",
      "permanent": true
    },
    {
      "source": "/snart.html",
      "destination": "/snart",
