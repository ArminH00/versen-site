    },
    {
      "source": "/gross-kontrollrum.html",
      "destination": "/gross-kontrollrum",
      "permanent": true
    },
    {
      "source": "/design-system/index.html",
      "destination": "/design-system",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/produkter",
      "destination": "/produkter.html"
    },
    {
      "source": "/produkt",
      "destination": "/produkt.html"
    },
    {
      "source": "/kundvagn",
      "destination": "/kundkorg.html"
    },
    {
      "source": "/checkout",
      "destination": "/checkout.html"
    },
    {
      "source": "/konto",
      "destination": "/konto.html"
    },
    {
      "source": "/medlemskap",
      "destination": "/medlemskap.html"
    },
    {
      "source": "/medlemskap-aktivt",
      "destination": "/medlemskap-aktivt.html"
    },
    {
      "source": "/drops",
      "destination": "/drops.html"
    },
