      "destination": "/forslag.html"
    },
    {
      "source": "/installningar",
      "destination": "/installningar.html"
    },
    {
      "source": "/order",
      "destination": "/order.html"
    },
    {
      "source": "/villkor",
      "destination": "/villkor.html"
    },
    {
      "source": "/integritet",
      "destination": "/integritet.html"
    },
    {
      "source": "/returer",
      "destination": "/returer.html"
    },
    {
      "source": "/faq",
      "destination": "/faq.html"
    },
    {
      "source": "/kontakt",
      "destination": "/kontakt.html"
    },
    {
      "source": "/snart",
      "destination": "/snart.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/gross-kontrollrum",
      "destination": "/gross-kontrollrum.html"
    },
    {
      "source": "/design-system",
      "destination": "/design-system/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
