SHOPIFY_STORE_DOMAIN=din-butik.myshopify.com
SHOPIFY_API_VERSION=2026-04

# Dev Dashboard-app. Rotera secret om den har delats i chat eller skärmdump.
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=
# Valfri override för Shopify webhook-HMAC. Om tom används SHOPIFY_APP_CLIENT_SECRET.
SHOPIFY_WEBHOOK_SECRET=

# Skapas en gång via /api/create-storefront-token och sparas sedan här.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Tillfällig launch-MVP för medlemsläge.
VERSEN_SETUP_SECRET=
VERSEN_MEMBER_ACCESS_CODE=
SHOPIFY_MEMBER_DISCOUNT_CODE=

# Mail via Resend.
RESEND_API_KEY=
VERSEN_EMAIL_FROM=Versen <hej@versen.se>
VERSEN_SUPPORT_EMAIL=hej@versen.se
VERSEN_SITE_URL=https://versen.se
VERSEN_EMAIL_VERIFICATION_SECRET=

# Stripe intern checkout. Lägg riktiga nycklar i Vercel/env, aldrig i frontend.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VERSEN_SHIPPING_ORE=4900
VERSEN_TAX_RATE=0.25

# Supabase orderdatabas. Secret key används endast i serverless API:er.
SUPABASE_URL=https://din-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_ORDERS_TABLE=orders
SUPABASE_ORDER_ITEMS_TABLE=order_items
SUPABASE_CHECKOUT_DRAFTS_TABLE=checkout_drafts

# Lokal fallback för order-store om Supabase-env saknas lokalt.
VERSEN_ORDER_STORE_PATH=
